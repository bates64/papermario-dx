#!/usr/bin/env python3

import os
import subprocess
import shutil
import platform

ROM = "ver/current/build/papermario.z64"
EMULATOR_PATHS = [
    "cen64",
    "ares",
    "mupen64plus",
    "retroarch",
    "Project64",
]
emulator = None

for command in EMULATOR_PATHS:
    if shutil.which(command) is not None:
        emulator = command
        break

    # WSl compat
    command += ".exe"
    if shutil.which(command) is not None:
        emulator = command
        break

def is_wsl(v: str = platform.uname().release) -> int:
    if v.endswith("-Microsoft"):
        return 1
    elif v.endswith("microsoft-standard-WSL2"):
        return 2
    return 0

def windows_path(path):
    return subprocess.check_output(["wslpath", "-w", path]).decode().strip()

def main():
    if not os.path.exists("build.ninja"):
        if os.system("./configure") != 0:
            print("error: configure failed")
            exit(1)

    os.system("clear")
    ret = os.system(f"n2 {ROM}")

    # n2 errors on missing inputs (e.g. deleted source directory) instead of
    # re-running the generator. Reconfigure and retry once.
    if ret != 0 and b"missing" in subprocess.run(
        ["n2", ROM], capture_output=True
    ).stderr:
        print("missing input, reconfiguring...")
        if os.system("./configure") != 0:
            print("error: configure failed")
            exit(1)
        ret = os.system(f"n2 {ROM}")

    if ret != 0:
        print("error: build failed")
        exit(1)

    wsl = is_wsl() != 0
    rom = windows_path(ROM) if wsl else ROM

    if emulator is not None:
        subprocess.Popen([emulator, rom], start_new_session=True)
    else:
        print("error: no emulator found")
        if wsl:
            print("  hint: add an emulator to your PATH")

if __name__ == "__main__":
    main()
